

# Clé API Mistral AI (obligatoire)
# Obtenir une clé : https://console.mistral.ai/
MISTRAL_API_KEY=votre_cle_api_ici

# Modèle Mistral pour les embeddings (ne pas modifier)
EMBEDDING_MODEL=mistral-embed

# Modèle Mistral pour le chat (peut être changé)
MISTRAL_MODEL=mistral-large-latest

# Taille des chunks pour le découpage des documents
CHUNK_SIZE=1000

# Chevauchement entre les chunks
CHUNK_OVERLAP=200