# ============================================================================
# RAG IT Support System - Configuration
# ============================================================================
# Copier ce fichier en .env et remplir les valeurs

# ============================================================================
# GROQ API (LLM Provider - Gratuit et Rapide)
# ============================================================================
# Obtenir une clé gratuite: https://console.groq.com/
MISTRAL_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx


# Modèles disponibles:
# - mixtral-8x7b-32768 (par défaut, très puissant)
# - llama2-70b-4096 (bon compromis)
# - gemma-7b-it (léger et rapide)
MISTRAL_MODEL=mixtral-8x7b-32768

# ============================================================================
# EMBEDDING MODEL (Modèle HuggingFace)
# ============================================================================
# Modèles recommandés:
# - sentence-transformers/all-MiniLM-L6-v2 (par défaut, 24MB)
# - sentence-transformers/all-mpnet-base-v2 (meilleur, 224MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# CHEMINS DE FICHIERS
# ============================================================================
VECTOR_DB_PATH=./vector_db
CSV_FILE=tickets_historiques.csv
DOCS_FOLDER=./docs

# ============================================================================
# CONFIGURATION DE LA VECTORISATION
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ============================================================================
# CONFIGURATION DU RAG
# ============================================================================
# Nombre de documents à récupérer pour chaque requête
NUM_SOURCES=3

# Température du LLM (0=déterministe, 1=créatif)
LLM_TEMPERATURE=0.3

# Max tokens pour la réponse
LLM_MAX_TOKENS=1000

# ============================================================================
# OLLAMA (Alternative locale - Optionnel)
# ============================================================================
# Pour utiliser Ollama au lieu de Groq (gratuit, pas d'API)
# 1. Installer: https://ollama.ai
# 2. Lancer: ollama serve
# 3. Décommenter ci-dessous

# OLLAMA_ENABLE=true
# OLLAMA_MODEL=mistral
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# STREAMLIT
# ============================================================================
STREAMLIT_THEME_primaryColor=#1f77b4
STREAMLIT_THEME_backgroundColor=#ffffff
STREAMLIT_THEME_secondaryBackgroundColor=#f0f2f6
